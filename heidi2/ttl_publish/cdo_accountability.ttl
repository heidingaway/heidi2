@prefix gc: <https://www.canada.ca/#> .
@prefix ochro: <https://gcxgce.sharepoint.com/teams/10001579/#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix wiki: <https://en.wikipedia.org/wiki/> .

<CDO_Job_Description_Template_December_2024.docx> a owl:Ontology ;
    rdfs:label "CDO Job Description Template" ;
    dcterms:issued "2024-12-01" 
    .

gc:chief_data_officer a rdfs:Class , schema:OrganizationRole ;
    rdfs:label  "Chief Data Officer"@en  ;
    gc:has_accountabilities gc:cdo_accountabilities ;
    gc:reports_to gc:chief_digital_service_officer
    .

gc:chief_technology_officer a rdfs:Class , schema:OrganizationRole ;
    rdfs:label  "Chief Technology Officer"@en  ;
    gc:has_accountabilities gc:cto_accountabilities ;
    gc:reports_to gc:chief_digital_service_officer
    .

gc:cdo_accountabilities a rdfs:Class .

gc:cdo_specific_accountabilities rdfs:subClassOf rdfs:cdo_accountabilities ;
    dcterms:hasPart 
        gc:cdo_accountability_1 ,
        gc:cdo_accountability_10 ,
        gc:cdo_accountability_2 ,
        gc:cdo_accountability_3 ,
        gc:cdo_accountability_4 ,
        gc:cdo_accountability_5 ,
        gc:cdo_accountability_6 ,
        gc:cdo_accountability_7 ,
        gc:cdo_accountability_8 ,
        gc:cdo_accountability_9
    .


gc:cdo_general_accountabilities rdfs:subClassOf gc:cdo_accountabilities ;
    dcterms:hasPart gc:cdo_accountability_11.

gc:cdo_accountability_1 dcterms:subject gc:leadership .

gc:cdo_accountability_2 dcterms:subject gc:governance .

gc:cdo_accountability_3 dcterms:subject gc:quality .

gc:cdo_accountability_4 dcterms:subject gc:collaboration .

gc:cdo_accountability_5 dcterms:subject gc:management .

gc:cdo_accountability_6 dcterms:subject gc:insights  .

gc:cdo_accountability_7 dcterms:subject gc:operations  .

gc:cdo_accountability_8 dcterms:subject gc:operations .

gc:cdo_accountability_9 dcterms:subject gc:operations  .

gc:cdo_accountability_10 dcterms:subject gc:innovation .

gc:cdo_accountability_11 dcterms:subject gc:innovation .

schema:OrganizationRole rdfs:subClassOf schema:Role  .

gc:cdso_specific_accountabilities rdfs:subClassOf gc:cdso_accountabilities .

gc:cdso_general_accountabilities rdfs:subClassOf gc:cdso_accountabilities .

gc:chief_digital_service_officer a rdfs:OrganizationRole ;
    gc:has_accountabilities gc:cdso_accountabilities ;
    gc:reports_to gc:deputy_head
    .
